{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python Django",
			"type": "debugpy",
			"request": "launch",
			"args": [
				"runserver"
			],
			"django": true,
			"autoStartBrowser": false,
			"program": "${workspaceFolder}\\manage.py"
		},
		{
			"name": "Python File",
			"type": "debugpy",
			"request": "launch",
			"program": "${file}",
			"console": "integratedTerminal",
			"django": true
		}
	]
}